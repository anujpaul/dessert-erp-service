{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DatabaseInitialization": {
    "ApplyMigrationsOnStartup": true,
    "SeedOnStartup": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://dessert-erp.azurewebsites.net"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "AzureStorage": {
    "ConnectionString": "",
    "FileShareName": "erp-files"
  },
  "JwtSettings": {
    "Secret": "DessertERP-SuperSecretKey-ChangeInProduction-MinLength32Chars!!",
    "Issuer": "DessertERP",
    "Audience": "DessertERP",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  }
}
